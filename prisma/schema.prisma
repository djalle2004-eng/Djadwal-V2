generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== ENUMS =====
enum Role {
  ADMIN
  USER
  PROFESSOR
  SCHEDULE_MANAGER
  MANAGER
  VIEWER
}

enum Permission {
  READ
  WRITE
  ADMIN
}

enum CourseType {
  LECTURE    // محاضرة
  TD         // أعمال موجهة
  TP         // أعمال تطبيقية
  EXAM       // فرض محروس
}

enum SessionType {
  REGULAR    // عادية
  EXTRA      // إضافية
  MAKEUP     // تعويضية
  EXAM       // امتحان
}

enum ProfessorType {
  PERMANENT  // دائم
  TEMPORARY  // مؤقت
}

enum DayOfWeek {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

// ===== MODELS =====

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  password      String?
  name          String?
  role          Role      @default(USER)
  permission    Permission @default(READ)
  emailVerified DateTime?
  image         String?
  resetToken    String?   @map("reset_token")
  resetExpiry   DateTime? @map("reset_expiry")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("User")
  @@index([email])
}

model AcademicYear {
  id          String    @id @default(uuid())
  year        String    @unique
  active      Boolean   @default(false)
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  semesters   Semester[]
  
  @@map("AcademicYear")
  @@index([active])
}

model Semester {
  id            String    @id @default(uuid())
  name          String
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  isCurrent     Boolean   @default(false) @map("is_current")
  academicYearId String   @map("academic_year_id")
  
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  sessions      Session[]
  extraSessions ExtraSession[]
  
  @@map("semesters")
  @@index([academicYearId])
}

model Department {
  id            String    @id @default(uuid())
  name          String    @unique
  code          String?   
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  specializations Specialization[]
  professors    Professor[]
  groups        Group[]
  
  @@map("Department")
}

model Specialization {
  id            String    @id @default(uuid())
  name          String
  code          String?
  departmentId  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  groups        Group[]
  
  @@map("Specialization")
  @@index([departmentId])
}

model Group {
  id               String    @id @default(uuid())
  name             String
  size             Int       @default(30)
  departmentId     String?
  specializationId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  department      Department? @relation(fields: [departmentId], references: [id])
  specialization  Specialization? @relation(fields: [specializationId], references: [id])
  assignments     Assignment[]
  extraSessions   ExtraSession[]
  
  @@map("Group")
  @@index([specializationId])
  @@index([departmentId])
}

model Professor {
  id            String        @id @default(uuid())
  name          String        
  email         String?       @unique
  phone         String?
  type          String?       @default("permanent")
  departmentId  String?
  maxHours      Int?          @map("max_hours")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  department    Department?   @relation(fields: [departmentId], references: [id])
  assignments   Assignment[]
  extraSessions ExtraSession[]
  
  @@map("Professor")
  @@index([departmentId])
  @@index([email])
}

model Course {
  id              String    @id @default(uuid())
  name            String
  code            String    @unique
  credits         Int?
  type            String?   @default("lecture")
  description     String?
  hoursPerWeek    Float?    @map("hours_per_week")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  assignments     Assignment[]
  extraSessions   ExtraSession[]
  
  @@map("Course")
  @@index([code])
}

model Room {
  id            String    @id @default(uuid())
  name          String    
  capacity      Int
  type          String?   // amphitheater, classroom, lab
  building      String?
  floor         Int?
  hasProjector  Boolean   @default(false) @map("has_projector")
  hasComputers  Boolean   @default(false) @map("has_computers")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  assignments     Assignment[]
  extraSessions ExtraSession[]
  
  @@map("Room")
}

model Assignment {
  id             String    @id @default(uuid())
  courseId       String
  professorId    String
  groupId        String?
  roomId         String?
  dayOfWeek      Int
  startTime      String
  endTime        String
  sessionType    String?   @default("lecture")
  academicYear   String?
  semester       String?
  specialization String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  group       Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  room        Room?     @relation(fields: [roomId], references: [id])
  
  @@map("Assignment")
  @@index([courseId])
  @@index([professorId])
  @@index([groupId])
}

model ExtraSession {
  id              String      @id @default(uuid())
  courseId        String
  professorId     String
  groupId         String?
  roomId          String
  sessionDate     String
  startTime       String
  endTime         String
  description     String?
  sessionType     String?
  academicYear    String?
  semester        String?     
  reason          String?
  isArchived      Boolean     @default(false)
  examNote        String?
  
  semesterId      String?     @map("semester_id") 
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  course          Course      @relation(fields: [courseId], references: [id])
  professor       Professor   @relation(fields: [professorId], references: [id])
  group           Group?      @relation(fields: [groupId], references: [id])
  room            Room        @relation(fields: [roomId], references: [id])
  semesterRel     Semester?   @relation(fields: [semesterId], references: [id])
  
  @@map("ExtraSession")
  @@index([courseId])
  @@index([professorId])
  @@index([roomId])
}

model Session {
  id          String    @id @default(uuid())
  semesterId  String    @map("semester_id")
  data        Json      // snapshot JSON للجدول الكامل
  name        String?   // اسم الـ sandbox
  isSandbox   Boolean   @default(false) @map("is_sandbox")
  createdAt   DateTime  @default(now())
  
  semester    Semester  @relation(fields: [semesterId], references: [id])
  
  @@map("sessions")
}

model PrintSettings {
  id              String    @id @default(uuid())
  universityName  String?   @map("university_name")
  facultyName     String?   @map("faculty_name")
  universityLogo  String?   @map("university_logo")
  facultyLogo     String?   @map("faculty_logo")
  headerNotes     String?   @map("header_notes")
  footerNotes     String?   @map("footer_notes")
  examNotes       String?   @map("exam_notes")
  updatedAt       DateTime  @updatedAt
  
  @@map("print_settings")
}
